<section class="contact-section">
    <div class="container-fluid">
        <div class="row g-0">

            <!-- Left Image -->
            <div class="col-lg-6 contact-img d-none d-lg-block"></div>

            <!-- Right Form -->
            <div class="col-lg-6 bg-white p-5 d-flex align-items-center">
                <div class="w-100 px-lg-5">
                    <h2 class="fw-bold mb-4">Свяжитесь с нами</h2>

                    <form>
                        <div class="mb-4">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" placeholder="Enter your Name">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" placeholder="Enter a valid email address">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Message</label>
