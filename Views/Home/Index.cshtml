                                I accept the <a href="#">Terms of Service</a>
                            </label>
                        </div>

                        <button type="submit" class="btn btn-dark-custom w-100">
                            ПРЕДСТАВЛЯТЬ НА РАССМОТРЕНИЕ
                        </button>

                        <p class="mt-4 text-muted small">
                            Изображение из <a href="#">Freepik</a>
                        </p>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
